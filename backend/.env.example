TELEGRAM_BOT_TOKEN=replace_with_your_bot_token
TELEGRAM_CHAT_ID=replace_with_your_chat_id

# Keep true outside an explicit local developer bypass.
AUTH_REQUIRED=true
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
AUTH_CACHE_SECONDS=45
ADMIN_EMAILS=owner@example.com

# Production XAU candles. Keep this token server-side only.
OANDA_API_TOKEN=replace_with_your_oanda_token
OANDA_ENVIRONMENT=live

# Mount a persistent Railway volume here so candle and Diamond history survives redeploys.
SH_DATA_DIR=/data

# Comma-separated production and local frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
