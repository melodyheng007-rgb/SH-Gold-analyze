TELEGRAM_BOT_TOKEN=replace_with_your_bot_token
TELEGRAM_CHAT_ID=replace_with_your_chat_id
TELEGRAM_COMMUNITY_URL=

# Keep true outside an explicit local developer bypass.
AUTH_REQUIRED=true
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
AUTH_CACHE_SECONDS=45
ADMIN_EMAILS=owner@example.com

# Cloudflare Turnstile protects public account forms. Configure the same secret
# in Supabase Auth > Attack Protection so email auth tokens are verified there.
TURNSTILE_SECRET_KEY=replace_with_turnstile_secret_key
TURNSTILE_ALLOWED_HOSTNAMES=your-domain.example,localhost
TURNSTILE_RATE_LIMIT_PER_MINUTE=10
# Optional application-level burst limit. Keep 0 when edge rate limiting is used.
API_RATE_LIMIT_PER_MINUTE=0

# Production XAU candles. Keep this token server-side only.
OANDA_API_TOKEN=replace_with_your_oanda_token
OANDA_ENVIRONMENT=live

# Mount a persistent Railway volume here so candle and Diamond history survives redeploys.
SH_DATA_DIR=/data

# Comma-separated production and local frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
