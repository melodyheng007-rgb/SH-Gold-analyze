VITE_API_BASE_URL=http://127.0.0.1:8001

# Supabase browser credentials. A publishable/anon key is safe for the browser;
# never place a service-role key or Google client secret in a VITE_ variable.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
VITE_AUTH_REQUIRED=true
VITE_TURNSTILE_SITE_KEY=replace_with_turnstile_site_key

# Public Telegram group invite, for example https://t.me/your_public_group
VITE_TELEGRAM_COMMUNITY_URL=https://t.me/replace_with_your_group
